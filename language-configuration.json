{
    "comments": {
        "lineComment": "---",
        "blockComment": [
            "---",
            "*---"
        ]
    },
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ]
    ],
    "autoClosingPairs": [
        {
            "open": "{",
            "close": "}"
        },
        {
            "open": "[",
            "close": "]"
        },
        {
            "open": "(",
            "close": ")"
        },
        {
            "open": "\"",
            "close": "\"",
            "notIn": [
                "string"
            ]
        },
        {
            "open": "<<<",
            "close": ">>>"
        }
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "\"",
            "\""
        ],
        [
            "<<<",
            ">>>"
        ]
    ],
    "onEnterRules": [
        {
            "beforeText": "\\b(then|do|\\{)\\s*;\\s*$",
            "action": {
                "indent": "indent"
            }
        },
        {
            "beforeText": "^\\s*(end|\\});?\\s*$",
            "action": {
                "indent": "outdent"
            }
        }
    ],
    "folding": {
        "markers": {
            "start": "\\b(func|fiber|if|while|for|serve)\\b",
            "end": "^\\s*(end;|\\};)"
        }
    },
    "wordPattern": "[a-zA-Z][a-zA-Z0-9_]*"
}