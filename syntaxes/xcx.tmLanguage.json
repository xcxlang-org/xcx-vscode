{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "XCX",
    "scopeName": "source.xcx",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#raw_blocks"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#fiber_type"
        },
        {
            "include": "#keywords_control"
        },
        {
            "include": "#keywords_fiber"
        },
        {
            "include": "#keywords_builtin"
        },
        {
            "include": "#keywords_logical"
        },
        {
            "include": "#keywords_set_ops"
        },
        {
            "include": "#types"
        },
        {
            "include": "#type_domains"
        },
        {
            "include": "#column_attributes"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#decorators"
        },
        {
            "include": "#terminal_commands"
        },
        {
            "include": "#io_operators"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#builtin_modules"
        },
        {
            "include": "#identifiers"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.xcx",
                    "match": "---.*$"
                }
            ]
        },
        "raw_blocks": {
            "patterns": [
                {
                    "name": "string.quoted.other.raw-block.xcx",
                    "begin": "<<<",
                    "end": ">>>",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.xcx"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.xcx"
                        }
                    }
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.xcx",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.xcx",
                            "match": "\\\\[ntr\"\\\\]"
                        }
                    ]
                }
            ]
        },
        "fiber_type": {
            "patterns": [
                {
                    "comment": "fiber:type: varname — typed fiber variable declaration",
                    "name": "storage.type.fiber.xcx",
                    "match": "\\bfiber(?::[a-zA-Z][a-zA-Z0-9_]*)?(?=\\s*:)"
                },
                {
                    "comment": "fiber:type: in function parameter",
                    "name": "storage.type.fiber.xcx",
                    "match": "\\bfiber(?::[a-zA-Z][a-zA-Z0-9_]*)?(?=\\s+[a-zA-Z])"
                }
            ]
        },
        "keywords_control": {
            "patterns": [
                {
                    "name": "keyword.control.xcx",
                    "match": "\\b(if|then|elseif|elif|elf|else|els|end|while|do|for|in|to|break|continue|return|include|as|yield|serve|const)\\b"
                }
            ]
        },
        "keywords_fiber": {
            "patterns": [
                {
                    "name": "keyword.declaration.fiber.xcx",
                    "match": "\\bfiber\\b"
                },
                {
                    "name": "keyword.declaration.func.xcx",
                    "match": "\\bfunc\\b"
                }
            ]
        },
        "keywords_builtin": {
            "patterns": [
                {
                    "name": "support.function.builtin.xcx",
                    "match": "\\b(halt|alert|error|fatal|terminal|store|random|choice|input|perf)\\b"
                },
                {
                    "comment": "'from' in random.choice from / yield from",
                    "name": "keyword.control.xcx",
                    "match": "\\bfrom\\b"
                }
            ]
        },
        "keywords_logical": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.xcx",
                    "match": "\\b(AND|OR|NOT|HAS)\\b"
                },
                {
                    "name": "keyword.operator.logical.xcx",
                    "match": "&&|\\|\\||!!"
                }
            ]
        },
        "keywords_set_ops": {
            "patterns": [
                {
                    "name": "keyword.operator.set.xcx",
                    "match": "\\b(UNION|INTERSECTION|DIFFERENCE|SYMMETRIC_DIFFERENCE)\\b"
                },
                {
                    "name": "keyword.operator.set.xcx",
                    "match": "[∪∩\\\\⊕]"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.xcx",
                    "match": "\\b(array|set|map|table|json|date|database)\\b"
                },
                {
                    "comment": "Single-letter primitive types only when used as type annotation (followed by :)",
                    "name": "storage.type.primitive.xcx",
                    "match": "(?<![a-zA-Z0-9_])\\b(i|f|s|b)\\b(?=\\s*:)"
                },
                {
                    "comment": "Long-form type aliases when used as type annotation (followed by :)",
                    "name": "storage.type.primitive.xcx",
                    "match": "(?<![a-zA-Z0-9_])\\b(int|float|str|bool)\\b(?=\\s*:)"
                },
                {
                    "comment": "Type cast functions: i(...), f(...), s(...)",
                    "name": "storage.type.primitive.xcx",
                    "match": "(?<![a-zA-Z0-9_])\\b(i|f|s)\\b(?=\\s*\\()"
                }
            ]
        },
        "type_domains": {
            "patterns": [
                {
                    "comment": "Set domain specifiers after set:",
                    "name": "support.type.domain.xcx",
                    "match": "(?<=set:)(N|Z|Q|S|B|C)\\b"
                }
            ]
        },
        "column_attributes": {
            "patterns": [
                {
                    "comment": "Table column attributes: @auto, @pk, @unique, @optional, @default, @fk",
                    "name": "keyword.other.column-attribute.xcx",
                    "match": "@(auto|pk|unique|optional|default|fk)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.xcx",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.null.xcx",
                    "match": "\\bEMPTY\\b"
                }
            ]
        },
        "decorators": {
            "patterns": [
                {
                    "name": "keyword.other.decorator.xcx",
                    "match": "@(step|wait)\\b"
                }
            ]
        },
        "terminal_commands": {
            "patterns": [
                {
                    "comment": ".terminal !command — full directive",
                    "name": "support.function.terminal.xcx",
                    "match": "\\.terminal\\s+!(clear|exit|run|raw|normal|cursor|move|write)\\b"
                }
            ]
        },
        "io_operators": {
            "patterns": [
                {
                    "name": "keyword.operator.output.xcx",
                    "match": ">!"
                },
                {
                    "name": "keyword.operator.input.xcx",
                    "match": ">\\?"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "comment": "Integer digit concatenation ++ (must come before arithmetic +)",
                    "name": "keyword.operator.concat.xcx",
                    "match": "\\+\\+"
                },
                {
                    "name": "keyword.operator.arithmetic.xcx",
                    "match": "\\^|[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.comparison.xcx",
                    "match": "==|!=|>=|<=|>|<"
                },
                {
                    "name": "keyword.operator.arrow.xcx",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.bridge.xcx",
                    "match": "<->|<=>"
                },
                {
                    "name": "keyword.operator.route.xcx",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.assignment.xcx",
                    "match": "(?<![=!<>])=(?!=)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.xcx",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.xcx",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "builtin_modules": {
            "patterns": [
                {
                    "name": "support.class.builtin.xcx",
                    "match": "\\b(crypto|net|env|date|store|random|input|perf)(?=\\.)"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "comment": "Function/fiber definitions — highlight name",
                    "name": "entity.name.function.xcx",
                    "match": "(?<=\\bfunc\\s|\\bfiber\\s)[a-zA-Z][a-zA-Z0-9_]*"
                },
                {
                    "name": "variable.other.xcx",
                    "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.statement.xcx",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.range.xcx",
                    "match": ",,"
                },
                {
                    "name": "punctuation.separator.xcx",
                    "match": ","
                },
                {
                    "name": "punctuation.accessor.xcx",
                    "match": "\\."
                },
                {
                    "name": "punctuation.section.block.xcx",
                    "match": "[\\{\\}\\[\\]\\(\\)]"
                }
            ]
        }
    }
}