{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "PAX Configuration",
    "scopeName": "source.pax",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#block_delimiters"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#arrays"
        },
        {
            "include": "#version"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#dep_formats"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.pax",
                    "begin": "^\\s*---\\s*$",
                    "end": "^\\s*\\*---\\s*$",
                    "patterns": []
                },
                {
                    "name": "comment.line.pax",
                    "match": "---.*$"
                }
            ]
        },
        "block_delimiters": {
            "patterns": [
                {
                    "name": "keyword.control.block.pax",
                    "match": "^\\s*/$"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.pax",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.pax",
                    "match": "\\\\."
                }
            ]
        },
        "arrays": {
            "name": "punctuation.definition.array.pax",
            "match": "[\\[\\]]"
        },
        "version": {
            "patterns": [
                {
                    "comment": "Version pin in dependency: name@1.2.0 or name@latest",
                    "name": "constant.numeric.version.pax",
                    "match": "@([0-9]+\\.[0-9]+\\.[0-9]+|latest)\\b"
                },
                {
                    "comment": "Semantic version string value: \"1.0.0\"",
                    "name": "constant.numeric.semver.pax",
                    "match": "(?<=\")[0-9]+\\.[0-9]+\\.[0-9]+(?=\")"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pax",
                    "match": "::"
                },
                {
                    "name": "punctuation.separator.pax",
                    "match": ","
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "support.type.property-name.pax",
                    "match": "\\b(name|version|author|description|main|tags|files|deps)\\b"
                }
            ]
        },
        "dep_formats": {
            "patterns": [
                {
                    "comment": "GitHub shortcut: user/repo",
                    "name": "entity.name.class.pax",
                    "match": "(?<=\")[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+(?=\")"
                },
                {
                    "comment": "Direct URL dependency",
                    "name": "markup.underline.link.pax",
                    "match": "https?://[^\"\\s]+"
                }
            ]
        }
    }
}